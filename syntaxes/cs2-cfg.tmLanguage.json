{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "CS2 Config",
	"patterns": [
		{ "include": "#comment" },
		{ "include": "#string" },
		{ "include": "#command" },
		{ "include": "#entity" },
		{ "include": "#keybind" },
		{ "include": "#binding" },
		{ "include": "#network" },
		{ "include": "#literal" },
		{ "include": "#separator" }
	],
	"repository": {
		"comment": {
			"patterns": [
				{
					"name": "comment.line.double-slash.cs2-cfg",
					"match": "//.*$"
				}
			]
		},
		"string": {
			"patterns": [
				{
					"name": "string.quoted.double.cs2-cfg",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{ "include": "#command" },
						{ "include": "#entity" },
						{ "include": "#keybind" },
						{ "include": "#binding" },
						{ "include": "#network" },
						{ "include": "#literal" },
						{ "include": "#separator" }
					]
				}
			]
		},
		"command": {
			"patterns": [
				{
					"name": "support.function.cs2-cfg",
					"match": "[+-](?:attack|attack2|back|duck|forward|jump|left|lookatweapon|reload|right|showscores|spray_menu|sprint|use|voicerecord)\\b"
				},
				{
					"name": "variable.parameter.cs2-cfg",
					"match": "\\b(?:starttimeout|relative|subclass_change|weapon_(?:c4|healthshot|knife|taser|cz75a|deagle|elite|fiveseven|glock|hkp2000|p250|revolver|tec9|usp_silencer|bizon|mac10|mp5sd|mp7|mp9|p90|ump45|mag7|nova|sawedoff|xm1014|m249|negev|ak47|aug|awp|famas|galilar|g3sg1|m4a1|m4a1_silencer|scar20|sg556|ssg08|flashbang|smokegrenade|hegrenade|molotov|incgrenade|decoy)|(?:flashbang|smokegrenade|hegrenade|molotov|decoy)_projectile)\\b"
				},
				{
					"name": "keyword.control.cs2-cfg",
					"match": "\\b(?:pitch|yaw|messagemode2?)\\b"
				}
			]
		},
		"entity": {
			"patterns": [
				{
					"name": "entity.name.class.cs2-cfg",
					"match": "\\b(?:defuser|taser|vest|vesthelm|cz75a|deagle|elite|fiveseven|glock|hkp2000|p250|revolver|tec9|usp_silencer|bizon|mac10|mp5sd|mp7|mp9|p90|ump45|mag7|nova|sawedoff|xm1014|m249|negev|ak47|aug|awp|famas|galilar|g3sg1|m4a1|m4a1_silencer|scar20|sg556|ssg08|flashbang|smokegrenade|hegrenade|molotov|incgrenade|decoy)\\b"
				},
				{
					"name": "entity.name.class.cs2-cfg",
					"match": "\\b(?:ar_(?:baggage|pool_day|shoots|shoots_night)|cs_(?:agency|italy|office)|de_(?:ancient|ancient_night|anubis|cache|dust2|golden|inferno|mirage|nuke|overpass|palacio|rooftop|train|vertigo)|lobby_mapveto)\\b"
				}
			]
		},
		"keybind": {
			"patterns": [
				{
					"begin": "\\b(bind)\\s+(\")",
					"end": "\"",
					"beginCaptures": {
						"1": { "name": "support.function.cs2-cfg" },
						"2": { "name": "punctuation.definition.string.begin.cs2-cfg" }
					},
					"endCaptures": {
						"0": { "name": "punctuation.definition.string.end.cs2-cfg" }
					},
					"patterns": [
						{
							"name": "constant.language.cs2-cfg",
							"match": "\\b(?:[0-9a-z]|`|SPACE|ENTER|ESCAPE|BACKSPACE|TAB|CAPSLOCK|SHIFT|CTRL|ALT|SEMICOLON|F(?:1[0-2]|[1-9])|MOUSE[1-5]|MOUSE_[XY]|MWHEEL(?:UP|DOWN)|(?:LEFT|RIGHT|UP|DOWN)ARROW|INS|DEL|HOME|END|PG(?:UP|DN)|KP_(?:INS|DEL|END|DOWNARROW|PGDN|LEFTARROW|5|RIGHTARROW|HOME|UPARROW|PGUP|SLASH|MULTIPLY|MINUS|PLUS|ENTER))\\b"
						},
						{
							"name": "constant.language.cs2-cfg",
							"match": "\\bscancode(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\b"
						}
					]
				},
				{
					"match": "\\b(bind)\\s+(\\S+)",
					"captures": {
						"1": { "name": "support.function.cs2-cfg" },
						"2": { "name": "constant.language.cs2-cfg" }
					}
				}
			]
		},
		"binding": {
			"patterns": [
				{
					"begin": "\\b(alias)\\s+(\")",
					"end": "\"",
					"beginCaptures": {
						"1": {
							"name": "support.function.cs2-cfg"
						},
						"2": {
							"name": "punctuation.definition.string.begin.cs2-cfg"
						}
					},
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.cs2-cfg"
						}
					},
					"contentName": "entity.name.type.cs2-cfg"
				},
				{
					"match": "\\b(alias)\\s+(\\S+)",
					"captures": {
						"1": {
							"name": "support.function.cs2-cfg"
						},
						"2": {
							"name": "entity.name.type.cs2-cfg"
						}
					}
				}
			]
		},
		"network": {
			"patterns": [
				{
					"name": "variable.other.cs2-cfg",
					"match": "\\b(25[0-5]|2[0-4][0-9]|[1][0-9][0-9]|[1-9][0-9]|[0-9])(\\.)(25[0-5]|2[0-4][0-9]|[1][0-9][0-9]|[1-9][0-9]|[0-9])(\\.)(25[0-5]|2[0-4][0-9]|[1][0-9][0-9]|[1-9][0-9]|[0-9])(\\.)(25[0-5]|2[0-4][0-9]|[1][0-9][0-9]|[1-9][0-9]|[0-9])(:)(270[0-9]{2})\\b",
					"captures": {
						"2": { "name": "punctuation.separator.cs2-cfg" },
						"4": { "name": "punctuation.separator.cs2-cfg" },
						"6": { "name": "punctuation.separator.cs2-cfg" },
						"8": { "name": "punctuation.separator.cs2-cfg" }
					}
				},
				{
					"name": "variable.other.cs2-cfg",
					"match": "\\b([a-z0-9](?:[a-z0-9-]*[a-z0-9])?)(\\.)([a-z0-9](?:[a-z0-9-]*[a-z0-9])?)(\\.)([a-z]{2,63})(:)(270[0-9]{2})\\b",
					"captures": {
						"2": { "name": "punctuation.separator.cs2-cfg" },
						"4": { "name": "punctuation.separator.cs2-cfg" },
						"6": { "name": "punctuation.separator.cs2-cfg" }
					}
				}
			]
		},
		"literal": {
			"patterns": [
				{
					"name": "constant.numeric.cs2-cfg",
					"match": "(?<![\\w.:])[+-]?(?:\\d+\\.\\d+|\\d+|\\.\\d+)(?![\\w.])"
				},
				{
					"name": "constant.language.cs2-cfg",
					"match": "\\b(?:true|false)\\b"
				}
			]
		},
		"separator": {
			"patterns": [
				{
					"name": "punctuation.separator.cs2-cfg",
					"match": "[;|]"
				}
			]
		}
	},
	"scopeName": "source.cs2-cfg"
}
