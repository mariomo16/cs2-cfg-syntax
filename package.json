{
	"name": "cs2-cfg-syntax",
	"displayName": "CS2 Config Syntax",
	"description": "Syntax highlighting for CS2 .cfg files",
	"publisher": "mario-morales-ortega",
	"icon": "./icon.webp",
	"version": "1.0.3",
	"engines": {
		"vscode": "^1.104.0"
	},
	"categories": [
		"Programming Languages",
		"Other"
	],
	"keywords": [
		"cs2",
		"counter-strike",
		"cfg",
		"config",
		"syntax",
		"highlighting",
		"game"
	],
	"activationEvents": [],
	"contributes": {
		"languages": [
			{
				"id": "cs2-cfg",
				"aliases": [
					"CS2 Config",
					"cs2-cfg"
				],
				"extensions": [
					".cfg"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "cs2-cfg",
				"scopeName": "source.cs2-cfg",
				"path": "./syntaxes/cs2-cfg.tmLanguage.json"
			}
		]
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/mariomo16/cs2-cfg-syntax"
	},
	"bugs": {
		"url": "https://github.com/mariomo16/cs2-cfg-syntax/issues"
	},
	"homepage": "https://github.com/mariomo16/cs2-cfg-syntax#readme",
	"license": "MIT"
}
