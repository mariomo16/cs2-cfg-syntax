{
	"name": "cs2-cfg-syntax",
	"displayName": "CS2 Config Support",
	"description": "Syntax highlighting & IntelliSense for CS2 .cfg files",
	"publisher": "mario-morales-ortega",
	"icon": "./icon.webp",
	"version": "1.3.0",
	"engines": {
		"vscode": "^1.120.0"
	},
	"categories": [
		"Programming Languages",
		"Other"
	],
	"keywords": [
		"cs2",
		"counter-strike",
		"cfg",
		"config",
		"syntax",
		"highlighting",
		"game"
	],
	"main": "./out/extension.js",
	"activationEvents": [],
	"contributes": {
		"languages": [
			{
				"id": "cs2-cfg",
				"aliases": [
					"CS2 Config",
					"cs2-cfg"
				],
				"extensions": [
					".cfg"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "cs2-cfg",
				"scopeName": "source.cs2-cfg",
				"path": "./syntaxes/cs2-cfg.tmLanguage.json"
			}
		]
	},
	"scripts": {
		"build": "tsc -p ./"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/mariomo16/cs2-cfg-syntax"
	},
	"bugs": {
		"url": "https://github.com/mariomo16/cs2-cfg-syntax/issues"
	},
	"homepage": "https://github.com/mariomo16/cs2-cfg-syntax#readme",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "24.13.2",
		"@types/vscode": "^1.120.0",
		"typescript": "6.0.3"
	}
}
